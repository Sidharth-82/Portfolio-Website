---
import { site } from '../../config/site';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-4 py-8 sm:flex-row">
    <p class="text-sm text-muted">© {year} {site.name}. Built with Astro.</p>
    <div class="flex items-center gap-4 text-sm">
      <a class="text-muted transition hover:text-accent" href={site.socials.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a class="text-muted transition hover:text-accent" href={site.socials.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a class="text-muted transition hover:text-accent" href={`mailto:${site.email}`}>Email</a>
    </div>
  </div>
</footer>
