---
import { getCollection } from 'astro:content';
import { renderMarkdown } from '../lib/markdown';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectGrid from '../components/react/ProjectGrid.tsx';
import type { ProjectData } from '../components/react/ProjectGrid.tsx';

const projects: ProjectData[] = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  // Strip the numeric ordering prefix so the deep-link slug is stable and
  // human-readable: `01-uwb-tracking` -> `uwb-tracking` (matches `/projects/#<slug>`
  // links from the roadmap, same convention as roadmap.astro).
  .map((p) => ({ slug: p.slug.replace(/^\d+-/, ''), ...p.data, html: renderMarkdown(p.body) }));
---

<BaseLayout title="Projects" description="Projects I have designed and built.">
  <section class="mx-auto flex w-full max-w-screen-2xl flex-1 flex-col px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-10">
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
        <span class="text-accent">Projects</span>
      </h1>
      <p class="mt-2 max-w-2xl text-muted">
        Click any tile for a detailed write-up and a link to the source.
      </p>
    </header>
    <ProjectGrid client:load projects={projects} fill />
  </section>
</BaseLayout>
