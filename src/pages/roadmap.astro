---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/react/Timeline.tsx';
import type { EraData } from '../components/react/Timeline.tsx';
import { eras } from '../config/roadmap';

const allNodes = await getCollection('roadmap');

// Build the eras (with their nodes) from config + content. The era a node
// belongs to is derived from its folder, so adding a node = dropping in a file.
const erasData: EraData[] = eras
  .slice()
  .sort((a, b) => a.order - b.order)
  .map((era) => ({
    id: era.id,
    title: era.title,
    subtitle: era.subtitle,
    kind: era.kind,
    entries: allNodes
      .filter((n) => n.id.split('/')[0] === era.collectionDir)
      .sort((a, b) => a.data.order - b.data.order)
      .map((n) => ({
        id: n.id,
        label: n.data.label,
        sublabel: n.data.sublabel,
        html: marked.parse(n.body) as string,
      })),
  }));
---

<BaseLayout title="Learning Roadmap" description="An interactive timeline of my learning journey.">
  <section class="mx-auto max-w-6xl px-4 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
        Learning <span class="text-accent">Roadmap</span>
      </h1>
      <p class="mt-2 max-w-2xl text-muted">
        Pick an era to zoom in, then click any node to read what happened (or what's planned).
      </p>
    </header>
    <Timeline client:load eras={erasData} />
  </section>
</BaseLayout>
